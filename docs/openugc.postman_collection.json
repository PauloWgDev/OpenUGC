                "exec": [
                  "if (true)\r",
                  "{\r",
                  "    const randomId = Math.floor(Math.random() * 1000000);\r",
                  "    const name = `Content ${randomId}`;\r",
                  "    const description = `This is just a test ${randomId}`;\r",
                  "    const tag = `tag${Math.floor(Math.random() * 10) + 1}`; // Random tag between tag1 and tag10\r",
                  "\r",
                  "    const content = {\r",
                  "    name: name,\r",
                  "    description: description,\r",
                  "    version: 1,\r",
                  "    tags: [tag]\r",
                  "    };\r",
                  "\r",
                  "    pm.environment.set(\"content_body\", JSON.stringify(content));\r",
                  "\r",
                  "    console.log(\"Generated content:\", content);\r",
                  "}"
