      "name": "authorization",
      "item": [
        {
          "name": "login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login response status\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 401, 429]);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    let jsonData;\r",
                  "\r",
                  "    try {\r",
                  "        jsonData = pm.response.json();\r",
                  "    } catch (e) {\r",
                  "        console.error(\"Response is not JSON:\", pm.response.text());\r",
                  "        return;\r",
                  "    }\r",
                  "\r",
                  "    // Adjust this depending on your AuthResponse structure\r",
                  "    const token = jsonData.token || jsonData.jwt || jsonData.accessToken;\r",
                  "\r",
                  "    if (token) {\r",
                  "        pm.environment.set(\"token\", token);\r",
                  "        console.log(\"Token saved:\", token);\r",
                  "    } else {\r",
                  "        console.warn(\"⚠️ Token not found in response:\", jsonData);\r",
                  "    }\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"{{username}}\",\r\n  \"credential\": \"{{password}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
